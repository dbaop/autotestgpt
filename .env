# API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
SERVER_PORT=8000
SECRET_KEY=autotestgpt-secret-key-change-in-production

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=autotestgpt

# Workspace Configuration
WORKSPACE=./workspace
REPORT_DIR=./report

# Model Configuration
DEFAULT_MODEL=deepseek/deepseek-chat
GPT_MODEL=gpt-4

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=./workspace/logs/autotestgpt.log

# Test Configuration
TEST_TIMEOUT=300
TEST_RETRY_COUNT=3
TEST_CONCURRENCY=5